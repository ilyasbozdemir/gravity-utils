{
    "name": "gravity-desktop",
    "version": "1.0.0",
    "author": "Ilyas Bozdemir",
    "description": "Premium Desktop Utility Toolkit by Ilyas Bozdemir",
    "main": "electron/main.js",
    "scripts": {
        "start": "cross-env NODE_ENV=development electron .",
        "build": "electron-builder",
        "clean": "powershell -Command \"Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue\""
    },
    "dependencies": {
        "electron-updater": "6.8.3",
        "pdf-lib": "1.17.1"
    },
    "devDependencies": {
        "electron": "^34.0.0",
        "electron-builder": "26.8.1",
        "cross-env": "^7.0.3"
    },
    "build": {
        "appId": "com.bozdemir.gravity",
        "productName": "GravityDesktop",
        "copyright": "Copyright © 2026 Ilyas Bozdemir",
        "directories": {
            "output": "dist"
        }
    }
}