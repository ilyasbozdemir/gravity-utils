{
    "name": "gravity-desktop",
    "version": "1.0.0",
    "author": "Ilyas Bozdemir",
    "description": "Premium Desktop Utility Toolkit by Ilyas Bozdemir",
    "main": "electron/main.js",
    "scripts": {
        "dev": "concurrently \"vite\" \"cross-env NODE_ENV=development electron .\"",
        "start": "cross-env NODE_ENV=development electron .",
        "ui:dev": "vite",
        "ui:build": "vite build",
        "build": "pnpm ui:build && electron-builder",
        "clean": "powershell -Command \"Remove-Item -Recurse -Force dist,out -ErrorAction SilentlyContinue\""
    },
    "dependencies": {
        "@pdf-lib/fontkit": "^1.1.1",
        "docx": "^9.6.0",
        "docx-preview": "^0.3.7",
        "electron-updater": "6.8.3",
        "file-saver": "^2.0.5",
        "framer-motion": "^11.0.0",
        "html2canvas": "^1.4.1",
        "jspdf": "^4.2.0",
        "jszip": "^3.10.1",
        "lucide-react": "^0.563.0",
        "pdf-lib": "1.17.1",
        "pdfjs-dist": "^4.10.38",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^7.13.1",
        "sonner": "^2.0.7",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@types/file-saver": "^2.0.7",
        "@types/react": "^18.2.55",
        "@types/react-dom": "^18.2.19",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "concurrently": "^8.2.2",
        "cross-env": "^7.0.3",
        "electron": "^34.5.8",
        "electron-builder": "26.8.1",
        "electron-reloader": "^1.2.3",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.3.3",
        "vite": "^5.1.4"
    },
    "build": {
        "appId": "com.bozdemir.gravity",
        "productName": "GravityDesktop",
        "copyright": "Copyright © 2026 Ilyas Bozdemir",
        "directories": {
            "output": "dist"
        }
    }
}